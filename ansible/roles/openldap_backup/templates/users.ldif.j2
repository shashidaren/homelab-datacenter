{% for user in ldap_users %}
dn: uid={{ user.uid }},ou=People,{{ ldap_base_dn }}
objectClass: inetOrgPerson
objectClass: posixAccount
objectClass: shadowAccount

cn: {{ user.cn }}
sn: {{ user.sn }}
givenName: {{ user.cn.split(' ')[0] }}
uid: {{ user.uid }}
uidNumber: {{ user.uidNumber }}
gidNumber: {{ user.gidNumber }}
homeDirectory: /home/{{ user.uid }}
loginShell: /bin/bash
mail: {{ user.uid }}@{{ ldap_domain }}
gecos: {{ user.cn }}
userPassword: {{ user_passwords.results[loop.index0].stdout }}

{% endfor %}
