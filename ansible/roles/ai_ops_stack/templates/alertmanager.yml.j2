global:
  resolve_timeout: 5m

route:
  group_by: ['alertname']
  group_wait: 10s
  group_interval: 5m
  repeat_interval: 1h
  receiver: 'telegram'

receivers:
- name: 'telegram'
  telegram_configs:
  - bot_token: "{{ vault_telegram_bot_token }}"
    chat_id: {{ vault_telegram_chat_id }}
    send_resolved: true
